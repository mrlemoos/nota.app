# nota-server on Railway: Docker avoids Railpack bind mounts on node_modules/.cache
# and apps/nota-marketing/node_modules/.astro (EBUSY on rm / npm ci).
FROM node:22-bookworm-slim AS build
WORKDIR /app

COPY . .
RUN npm ci
RUN cd apps/nota-server && npm run build

ENV NODE_ENV=production
EXPOSE 8787
CMD ["node", "apps/nota-server/dist/index.js"]
