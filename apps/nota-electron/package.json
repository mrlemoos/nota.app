{
  "name": "@nota.app/nota-electron",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "wait-on": "^8.0.0"
  },
  "devDependencies": {
    "@types/wait-on": "^5.3.4",
    "electron": "35.7.5"
  },
  "nx": {
    "sourceRoot": "apps/nota-electron/src",
    "projectType": "application",
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "cd apps/nota-electron && npx tsc"
          ]
        }
      },
      "dev": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "echo 'Loads http://localhost:4200 — run `nx run-many -t dev` to start Vite and Electron together.'",
            "cd apps/nota-electron && npm run build && npx electron ."
          ]
        }
      },
      "electron:pack": {
        "executor": "nx:run-commands",
        "dependsOn": [
          {
            "target": "build",
            "projects": "nota.app"
          },
          {
            "target": "build",
            "projects": "self"
          }
        ],
        "options": {
          "commands": [
            "cd apps/nota-electron && npx electron-builder"
          ]
        }
      }
    },
    "tags": []
  }
}