{
  "name": "@nota.app/nota-server",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npx esbuild src/index.ts --bundle --platform=node --target=node22 --format=esm --packages=external --outfile=dist/index.js",
    "dev": "bun run src/index.ts",
    "start": "node dist/index.js",
    "test": "bun test src/"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.7",
    "cors": "^2.8.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.9",
    "bun-types": "^1.2.5"
  },
  "nx": {
    "sourceRoot": "apps/nota-server/src",
    "projectType": "application",
    "tags": [],
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "apps/nota-server",
          "command": "npm run build"
        }
      },
      "dev": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "apps/nota-server",
          "command": "npm run dev"
        }
      }
    }
  }
}
