# Supabase (same project as the SPA). Secret key is server-only — never expose to the client.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=

# Optional alias if you only have VITE_ names in your shell:
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=  # not required on the server

# RevenueCat secret API key (Project settings → API keys → Secret)
REVENUECAT_SECRET_API_KEY=

# Comma-separated allowed browser origins (production web app + Electron)
# Example: https://nota.app,https://www.nota.app,http://127.0.0.1:4378
NOTA_SERVER_CORS_ORIGINS=

# Port (default 8787)
# PORT=8787
