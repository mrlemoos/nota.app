# Clerk (same instance as the SPA)
CLERK_SECRET_KEY=

# xAI — assistive audio-to-note (`POST /api/audio-to-note`) only
XAI_API_KEY=
# Optional; default on server is grok-3
# XAI_CHAT_MODEL=grok-3

# Semantic Search — embeddings for pgvector (`POST …/v1/embeddings`, OpenAI-compatible).
# xAI does not expose raw embeddings for external vector DBs; use OpenAI or another compatible host.
NOTA_SEMANTIC_EMBEDDINGS_API_KEY=
# Defaults: OpenAI official API (see semantic-embeddings.server.ts)
# NOTA_SEMANTIC_EMBEDDINGS_API_BASE=https://api.openai.com/v1
# NOTA_SEMANTIC_EMBEDDINGS_MODEL=text-embedding-3-small
# Must match Postgres `vector(N)` in migration `note_semantic_index.embedding` (default 1536)
# NOTA_SEMANTIC_EMBEDDINGS_DIMENSIONS=1536

# Supabase — semantic index reads/writes (`note_semantic_index`) via service role (server only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
