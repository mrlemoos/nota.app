---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SiteHeader from '@/components/SiteHeader.astro';

const title = 'Note JSON → plain text — Nota';
const description =
  'Paste TipTap or ProseMirror document JSON and extract literal text. Runs in your browser; no account required.';
---

<BaseLayout title={title} description={description} canonicalPath="/tools/note-text-preview" image="/og-default.png">
  <main id="main-content">
    <SiteHeader />
    <div class="mx-auto max-w-3xl px-6 py-16 md:px-10 md:py-20">
      <h1 class="mb-3 font-serif text-3xl font-normal text-foreground md:text-4xl">Note JSON → plain text</h1>
      <p class="mb-8 max-w-2xl text-muted-foreground">
        Handy if you export or copy document JSON from Nota (or another TipTap app) and want a quick plain-text
        preview. Only <span class="text-foreground/90">text</span> nodes are concatenated—no rendering of marks or
        custom blocks.
      </p>

      <form id="nota-doc-text-form" class="space-y-4">
        <label class="block text-sm font-medium text-foreground" for="nota-doc-json-input"> Document JSON </label>
        <textarea
          id="nota-doc-json-input"
          name="json"
          rows="12"
          class="w-full rounded-[var(--radius)] border border-border bg-card p-3 font-mono text-sm text-card-foreground shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-ring"
          placeholder='{"type":"doc","content":[{"type":"paragraph","content":[{"type":"text","text":"Hello"}]}]}'
        ></textarea>
        <div class="flex flex-wrap gap-3">
          <button
            type="submit"
            class="mkt-focus inline-flex min-h-10 items-center justify-center rounded-[var(--radius)] bg-primary px-5 text-sm font-medium text-primary-foreground transition hover:opacity-90"
          >
            Extract text
          </button>
          <button
            type="button"
            id="nota-doc-text-clear"
            class="mkt-focus inline-flex min-h-10 items-center justify-center rounded-[var(--radius)] border border-border bg-background px-5 text-sm font-medium text-foreground transition hover:bg-muted"
          >
            Clear
          </button>
        </div>
      </form>

      <div class="mt-8">
        <h2 class="mb-2 text-sm font-medium text-foreground">Output</h2>
        <output
          id="nota-doc-text-output"
          class="block min-h-[4rem] whitespace-pre-wrap rounded-[var(--radius)] border border-border bg-muted/30 p-4 text-sm text-foreground"
          aria-live="polite"
        >
        </output>
      </div>

      <p class="mt-10 text-center text-sm text-muted-foreground">
        <a href="/" class="mkt-focus underline decoration-border underline-offset-4 hover:text-foreground">← Home</a>
      </p>
    </div>
  </main>
</BaseLayout>

<script>
  import { extractPlainTextFromDocJson } from '@nota/note-doc-plain-text';

  const form = document.getElementById('nota-doc-text-form');
  const input = document.getElementById('nota-doc-json-input');
  const output = document.getElementById('nota-doc-text-output');
  const clearBtn = document.getElementById('nota-doc-text-clear');

  if (form instanceof HTMLFormElement && input instanceof HTMLTextAreaElement && output instanceof HTMLOutputElement) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const raw = input.value.trim();
      if (!raw) {
        output.textContent = '';
        return;
      }
      try {
        const parsed: unknown = JSON.parse(raw);
        output.textContent = extractPlainTextFromDocJson(parsed) || '(No text nodes found)';
      } catch {
        output.textContent = 'Invalid JSON.';
      }
    });
  }

  if (clearBtn instanceof HTMLButtonElement && input instanceof HTMLTextAreaElement && output instanceof HTMLOutputElement) {
    clearBtn.addEventListener('click', () => {
      input.value = '';
      output.textContent = '';
    });
  }
</script>
