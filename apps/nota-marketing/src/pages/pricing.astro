---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import { NOTA_GITHUB_LATEST } from '@/lib/site';

const site = Astro.site;
if (!site) {
  throw new Error('Marketing site requires `site` in astro.config.');
}
const siteRoot = new URL('/', site).href;
const pricingUrl = new URL('/pricing', site).href;

/** Guide amounts; keep in sync with Clerk Billing / Stripe (USD). */
const priceMonthlyUsd = '2.49';
const priceAnnualUsd = '19.49';

const pricingTitle = 'Nota Pricing — From $2.49/month';
const pricingDescription =
  'Nota is a paid Mac notes app: subscribe in-app for cloud sync and backup. Guide prices $19.49/year or $2.49/month (USD); lifetime offered when available in checkout.';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: siteRoot,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Pricing',
          item: pricingUrl,
        },
      ],
    },
    {
      '@type': 'SoftwareApplication',
      name: 'Nota',
      operatingSystem: 'macOS',
      applicationCategory: 'ProductivityApplication',
      description:
        'Native Mac notes app. Subscribe inside the app after install for full access, cloud sync, and backup.',
      url: siteRoot,
      offers: [
        {
          '@type': 'Offer',
          name: 'Nota — annual',
          price: priceAnnualUsd,
          priceCurrency: 'USD',
          description: 'Full app access; billed annually. Subscribe from Settings in the macOS app.',
          availability: 'https://schema.org/OnlineOnly',
          url: pricingUrl,
        },
        {
          '@type': 'Offer',
          name: 'Nota — monthly',
          price: priceMonthlyUsd,
          priceCurrency: 'USD',
          description: 'Full app access; billed monthly. Subscribe from Settings in the macOS app.',
          availability: 'https://schema.org/OnlineOnly',
          url: pricingUrl,
        },
      ],
    },
  ],
};
---

<BaseLayout image="/og/pricing.png" title={pricingTitle} description={pricingDescription}>
  <script type="application/ld+json" slot="head-extras" is:inline set:html={JSON.stringify(structuredData)} />
  <main id="main-content">
    <SiteHeader />
    <div class="mx-auto max-w-5xl px-6 py-16 md:px-10 md:py-24">
      <h1 class="mb-4 font-serif text-4xl font-normal text-foreground md:text-5xl">Pricing</h1>
      <p class="mb-14 max-w-2xl text-lg text-muted-foreground">
        Nota is <span class="text-foreground/90">not</span> free to use: download the Mac app, sign in, then subscribe
        in Settings. The app binary is a free download from GitHub Releases; writing, sync, and backup require an
        active plan. Figures below are in <span class="text-foreground/90">USD</span>; taxes may apply by region, and
        the in-app checkout shows the final charge.
      </p>

      <div class="grid gap-8 md:grid-cols-3">
        <article class="rounded-[var(--radius)] border border-primary/25 bg-sidebar p-8 shadow-sm ring-1 ring-primary/15 md:min-h-[22rem]">
          <h2 class="mb-2 font-serif text-2xl text-sidebar-foreground">Annual</h2>
          <p class="text-3xl font-semibold tracking-tight text-sidebar-foreground">
            {'$' + priceAnnualUsd + ' / year'}
          </p>
          <p class="mb-6 text-sm font-medium text-primary">Save about 35% vs monthly</p>
          <ul class="space-y-3 text-sm text-muted-foreground">
            <li>Full app access</li>
            <li>Cloud sync and secure backup</li>
            <li>Use on the devices where you sign in</li>
          </ul>
        </article>

        <article class="rounded-[var(--radius)] border border-border bg-card p-8 shadow-sm md:min-h-[22rem]">
          <h2 class="mb-2 font-serif text-2xl text-card-foreground">Monthly</h2>
          <p class="mb-6 text-3xl font-medium tracking-tight text-card-foreground">
            {'$' + priceMonthlyUsd + ' / month'}
          </p>
          <ul class="space-y-3 text-sm text-muted-foreground">
            <li>Same features as annual</li>
            <li>Cancel through your billing provider</li>
          </ul>
        </article>

        <article class="rounded-[var(--radius)] border border-border bg-card p-8 shadow-sm md:min-h-[22rem]">
          <h2 class="mb-2 font-serif text-2xl text-card-foreground">Lifetime</h2>
          <p class="mb-6 text-3xl font-medium tracking-tight text-card-foreground">In-app</p>
          <p class="mb-6 text-sm leading-relaxed text-muted-foreground">
            When offered in your build of Nota, lifetime is a one-time purchase alongside monthly and yearly. Open
            Settings after sign-in to see current packages and prices.
          </p>
          <ul class="space-y-3 text-sm text-muted-foreground">
            <li>One-time billing where available</li>
            <li>Same entitlement as subscription while supported</li>
          </ul>
        </article>
      </div>

      <div class="mt-10 rounded-[var(--radius)] border border-border bg-muted/20 p-6 text-sm text-muted-foreground">
        <a
          href={NOTA_GITHUB_LATEST}
          class="mkt-focus inline-flex min-h-11 items-center justify-center rounded-[var(--radius)] bg-primary px-5 py-2.5 font-medium text-primary-foreground transition hover:opacity-90"
        >
          Download for macOS
        </a>
        <p class="mt-4 leading-relaxed">
          Complete checkout from <span class="font-medium text-foreground">Settings</span> in the app. No separate
          purchase page on this site.
        </p>
        <p class="mt-3">
          <a
            href="/refunds"
            class="mkt-focus font-medium text-foreground underline decoration-border underline-offset-4 hover:text-foreground"
            >Refund policy</a
          >
          for web-billed subscriptions.
        </p>
      </div>

      <p class="mt-14 text-center text-sm text-muted-foreground">
        <a href="/" class="mkt-focus underline decoration-border underline-offset-4 hover:text-foreground">← Back home</a>
      </p>
    </div>
  </main>
</BaseLayout>
