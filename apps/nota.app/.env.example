# Vercel (dashboard): set the same keys for Production / Preview when deploying `apps/nota.app`.
# Project Root Directory = `apps/nota.app`; install/build are overridden by `apps/nota.app/vercel.json`
# (install from monorepo root, `nx build @nota.app/nota.app`).

# Supabase Configuration
# Get these from your Supabase project dashboard: https://app.supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# RevenueCat Web Billing (public SDK key from Apps & providers → Web Billing app)
VITE_REVENUECAT_API_KEY=

# RevenueCat secret API key (Project settings → API keys → Secret) — server-only; never expose to the client
REVENUECAT_SECRET_API_KEY=

# Optional (local dev only): service role key for scripts/bootstrap-dev-user.ts — never expose to the client or commit real values
# SUPABASE_SERVICE_ROLE_KEY=
