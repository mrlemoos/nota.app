# Vercel (dashboard): set the same keys for Production / Preview when deploying `apps/nota.app`.
# Project Root Directory = `apps/nota.app`; install/build are overridden by `apps/nota.app/vercel.json`
# (install from monorepo root, `nx build @nota.app/nota.app`).

# Supabase Configuration
# Get these from your Supabase project dashboard: https://app.supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Bun nota-server base URL (no trailing slash) for Nota Pro entitlement + invalidate.
# When unset, the SPA uses same-origin /api/* (Vercel serverless).
# VITE_NOTA_SERVER_API_URL=https://your-nota-server.example.com

# RevenueCat Web Billing (public SDK key from Apps & providers → Web Billing app)
VITE_REVENUECAT_API_KEY=

# RevenueCat secret API key (Project settings → API keys → Secret) — server-only; never expose to the client
REVENUECAT_SECRET_API_KEY=

# Optional: Stripe (https://dashboard.stripe.com/apikeys) — use live keys only in production hosts; rotate if leaked.
# Publishable key (pk_live_… / pk_test_…): only needed if the SPA loads Stripe.js directly (not required for RevenueCat Web Billing).
VITE_STRIPE_PUBLISHABLE_KEY=
# Secret key (sk_live_… / sk_test_…): server-only for Vercel `api/*` or scripts; never use a `VITE_*` name for secrets.
STRIPE_SECRET_KEY=

# Optional (local dev only): service role key for scripts/bootstrap-dev-user.ts — never expose to the client or commit real values
# SUPABASE_SERVICE_ROLE_KEY=
