# Vercel (dashboard): set the same keys for Production / Preview when deploying `apps/nota.app`.
# Project Root Directory = `apps/nota.app`; install/build are overridden by `apps/nota.app/vercel.json`
# (install from monorepo root, `nx build @nota.app/nota.app`).

# Clerk (https://dashboard.clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=
# Electron desktop OAuth: add redirect allowlist entry `nota://oauth-callback` (Clerk Dashboard → Redirect URLs).
# Server-only (Vercel / nota-server / local API middleware): never expose to the client
CLERK_SECRET_KEY=
# Optional mirror of publishable key for cookie session resolution in serverless (if not using VITE_* in Node)
# CLERK_PUBLISHABLE_KEY=

# Supabase Configuration (Postgres + Storage; auth is Clerk + third-party JWT)
# Get these from your Supabase project dashboard: https://app.supabase.com
# Enable Clerk under Authentication → Third-party auth and run migration `0008_clerk_third_party_auth.sql`.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Required for Nota Pro (web + desktop): nota-server origin (no trailing slash). Entitlement and invalidate use Bearer JWT to this host only.
# Local dev: run apps/nota-server and set e.g. http://127.0.0.1:8787
# VITE_NOTA_SERVER_API_URL=https://your-nota-server.example.com

# Optional: Stripe (https://dashboard.stripe.com/apikeys) — use live keys only in production hosts; rotate if leaked.
# Publishable key (pk_live_… / pk_test_…): only needed if the SPA loads Stripe.js directly.
VITE_STRIPE_PUBLISHABLE_KEY=
# Secret key (sk_live_… / sk_test_…): server-only for Vercel `api/*` or scripts; never use a `VITE_*` name for secrets.
STRIPE_SECRET_KEY=

# Optional (local / CI only): Supabase service role for admin SQL or one-off migrations — never expose to the client or commit real values
# SUPABASE_SERVICE_ROLE_KEY=
